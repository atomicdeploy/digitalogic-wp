          "id": "__TELEGRAM_CREDENTIAL_ID__",
          "name": "__TELEGRAM_CREDENTIAL_NAME__"
        }
      },
      "onError": "continueRegularOutput",
      "continueOnFail": true,
      "retryOnFail": false,
      "maxTries": 1,
      "waitBetweenTries": 0
    },
    {
      "parameters": {
        "method": "POST",
