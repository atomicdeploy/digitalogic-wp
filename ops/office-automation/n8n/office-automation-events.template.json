        "url": "__SIP_NOTIFY_URL__",
        "sendHeaders": true,
        "sendBody": true,
        "contentType": "raw",
        "rawContentType": "application/json",
        "body": "={{ $('Normalize Office Automation Event').item.json.sipPayload }}",
        "options": {
          "timeout": 3000
