        injectLateLoginOverrides();
        buildLoginHeroCarousel();
        observeAuthChrome();
        bindLoginValidation();
        bindDigitsAutoIdentity();
        enforceDigitsRegisterMobile();
        bindLoadingStates();
        observeInlineMessages();
        bindErrorHandling();
        enableRipples();
    });
